{
  "name": "ultrawhale",
  "image": "golang:1.24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/go:1": {}
  },
  "postCreateCommand": "go mod download && go build -o bin/ultrawhale ./cmd/whale",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "github.vscode-github-actions",
        "task.vscode-task"
      ]
    }
  }
}
